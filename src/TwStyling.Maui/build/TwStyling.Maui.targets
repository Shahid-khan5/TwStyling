<Project>

  <!--
    Imported after the consuming project, so its XAML globs are already known. The generator reads
    .xaml through AdditionalFiles to precompile tw:Tw.Class literals into static StylePlan data.
    Excluding @(AdditionalFiles) keeps this a no-op if the consumer already added them by hand.
  -->
  <ItemGroup Condition="'$(TwPrecompile)' == 'true'">
    <AdditionalFiles Include="**\*.xaml"
                     Exclude="@(AdditionalFiles);bin\**\*.xaml;obj\**\*.xaml"
                     Visible="false" />
  </ItemGroup>

  <!--
    TwPrecompile=false must also unload the generator, otherwise it keeps harvesting C# .Tw("...")
    literals and emitting preloads. TwStyling.Analyzers stays loaded either way: TW0001 validation is
    independent of precompilation.
  -->
  <Target Name="TwRemoveGenerator" BeforeTargets="CoreCompile" Condition="'$(TwPrecompile)' != 'true'">
    <ItemGroup>
      <Analyzer Remove="@(Analyzer)" Condition="'%(Filename)%(Extension)' == 'TwStyling.Generators.dll'" />
    </ItemGroup>
  </Target>

  <!--
    ============================================================================================
    The CSS pipeline.

    When the project has a Tailwind entry stylesheet, the real Tailwind CLI compiles it (scanning
    the project's own .xaml/.cs for class strings) and the result is handed to the generator as an
    AdditionalFile. The generator lowers that CSS into StylePlans at build time, so the Tailwind
    vocabulary — arbitrary values, @theme tokens, @utility, @custom-variant — is understood exactly
    as Tailwind defines it, and nothing is parsed at runtime.

    A project need not write a tw.css: without one, a default entry stylesheet is generated into obj
    (see TwDefaultEntry below) so the pipeline still runs and Tailwind is still the single source of
    truth. Adding a tw.css is how you customise — @theme tokens, @utility, plugins, safelists.
    ============================================================================================
  -->

  <PropertyGroup>
    <TwUseCssPipeline Condition="'$(TwUseCssPipeline)' == ''">true</TwUseCssPipeline>
    <TwCssEntry Condition="'$(TwCssEntry)' == '' AND Exists('$(MSBuildProjectDirectory)\tw.css')">$(MSBuildProjectDirectory)\tw.css</TwCssEntry>

    <!--
      $(BaseIntermediateOutputPath) ("obj\"), not $(IntermediateOutputPath): this file is imported
      from the project body, and the SDK does not set IntermediateOutputPath until its own targets
      are imported afterwards. Using it here would evaluate to empty and write the stylesheet into
      the project directory. $(TargetFramework) keeps concurrent inner builds of a multi-targeted
      project off each other's output.
    -->
    <TwIntermediateDir Condition="'$(TwIntermediateDir)' == ''">$(BaseIntermediateOutputPath)tw\$(TargetFramework)\</TwIntermediateDir>
    <TwGeneratedCss Condition="'$(TwGeneratedCss)' == ''">$(TwIntermediateDir)tailwind.css</TwGeneratedCss>

    <TailwindCliVersion Condition="'$(TailwindCliVersion)' == ''">v4.3.2</TailwindCliVersion>

    <!-- No tw.css in the project: generate a default entry so the pipeline still runs. -->
    <_TwDefaultEntry Condition="'$(TwCssEntry)' == ''">$(TwIntermediateDir)tw.css</_TwDefaultEntry>
    <TwCssEntry Condition="'$(TwCssEntry)' == ''">$(_TwDefaultEntry)</TwCssEntry>

    <_TwCssEnabled Condition="'$(TwUseCssPipeline)' == 'true'">true</_TwCssEnabled>
    <_TwCssEnabled Condition="'$(_TwCssEnabled)' == ''">false</_TwCssEnabled>
  </PropertyGroup>

  <!--
    The default entry stylesheet, used when the project does not supply its own tw.css. It is the
    stylesheet a MAUI project would write by hand: Tailwind, the native variants, and a scan of the
    project's own sources. Writing a tw.css in the project overrides it entirely.

    @source paths are relative to this file (in obj), hence the walk back up to the project.
  -->
  <Target Name="TwWriteDefaultEntry"
          Condition="'$(_TwCssEnabled)' == 'true' AND '$(_TwDefaultEntry)' != ''">

    <MakeDir Directories="$(TwIntermediateDir)" />

    <PropertyGroup>
      <_TwProjectFromEntry>$([MSBuild]::MakeRelative($(TwIntermediateDir), $(MSBuildProjectDirectory)).Replace('\','/'))</_TwProjectFromEntry>
    </PropertyGroup>

    <!--
      An item's Include is not a string literal: MSBuild treats ';' as an item separator and '*' as
      a wildcard to expand against the filesystem. Both appear in CSS. They must be escaped — %3B
      and %2A — or the @source globs silently expand to nothing and the file loses those lines.
    -->
    <ItemGroup>
      <_TwDefaultEntryLine Include="@import &quot;tailwindcss&quot;%3B" />
      <_TwDefaultEntryLine Include="/%2A Native variants. Tailwind passes an unknown media type through verbatim, and the" />
      <_TwDefaultEntryLine Include="   engine resolves it at build time for the platform head being compiled. %2A/" />
      <_TwDefaultEntryLine Include="@custom-variant windows (@media windows)%3B" />
      <_TwDefaultEntryLine Include="@custom-variant android (@media android)%3B" />
      <_TwDefaultEntryLine Include="@custom-variant ios (@media ios)%3B" />
      <_TwDefaultEntryLine Include="@custom-variant mac (@media mac)%3B" />
      <_TwDefaultEntryLine Include="@custom-variant phone (@media phone)%3B" />
      <_TwDefaultEntryLine Include="@custom-variant tablet (@media tablet)%3B" />
      <_TwDefaultEntryLine Include="@custom-variant desktop (@media desktop)%3B" />
      <_TwDefaultEntryLine Include="/%2A MAUI has no CSS :hover/:active on elements. These map to the engine's state vector. %2A/" />
      <_TwDefaultEntryLine Include="@custom-variant pressed (&amp;:active)%3B" />
      <_TwDefaultEntryLine Include="@source &quot;$(_TwProjectFromEntry)/%2A%2A/%2A.xaml&quot;%3B" />
      <_TwDefaultEntryLine Include="@source &quot;$(_TwProjectFromEntry)/%2A%2A/%2A.cs&quot;%3B" />
      <_TwDefaultEntryLine Include="@source not &quot;$(_TwProjectFromEntry)/obj/%2A%2A&quot;%3B" />
      <_TwDefaultEntryLine Include="@source not &quot;$(_TwProjectFromEntry)/bin/%2A%2A&quot;%3B" />
    </ItemGroup>

    <WriteLinesToFile File="$(_TwDefaultEntry)" Lines="@(_TwDefaultEntryLine)"
                      Overwrite="true" WriteOnlyWhenDifferent="true" />
  </Target>

  <!--
    The standalone CLI is a Node-free binary published per platform. It is cached in the NuGet
    global-packages folder, so it is fetched once per machine rather than once per project. Set
    $(TailwindCliPath) to a binary you manage yourself — required for offline builds, and the
    recommended setup for CI.
  -->
  <PropertyGroup Condition="'$(_TwCssEnabled)' == 'true' AND '$(TailwindCliPath)' == ''">
    <_TwCliAsset Condition="$([MSBuild]::IsOSPlatform('Windows'))">tailwindcss-windows-x64.exe</_TwCliAsset>
    <_TwCliAsset Condition="$([MSBuild]::IsOSPlatform('Linux'))">tailwindcss-linux-x64</_TwCliAsset>
    <_TwCliAsset Condition="$([MSBuild]::IsOSPlatform('OSX')) AND $([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture) == 'Arm64'">tailwindcss-macos-arm64</_TwCliAsset>
    <_TwCliAsset Condition="$([MSBuild]::IsOSPlatform('OSX')) AND '$(_TwCliAsset)' == ''">tailwindcss-macos-x64</_TwCliAsset>

    <_TwCliCacheDir Condition="'$(NuGetPackageRoot)' != ''">$(NuGetPackageRoot)tailwindcss-cli\$(TailwindCliVersion)\</_TwCliCacheDir>
    <_TwCliCacheDir Condition="'$(NuGetPackageRoot)' == ''">$(TwIntermediateDir)cli\</_TwCliCacheDir>

    <TailwindCliPath>$(_TwCliCacheDir)$(_TwCliAsset)</TailwindCliPath>
    <_TwCliUrl>https://github.com/tailwindlabs/tailwindcss/releases/download/$(TailwindCliVersion)/$(_TwCliAsset)</_TwCliUrl>
  </PropertyGroup>

  <Target Name="TwRestoreCli" Condition="'$(_TwCssEnabled)' == 'true' AND !Exists('$(TailwindCliPath)')">

    <Error Condition="'$(_TwCliAsset)' == ''" Code="TW1001"
           Text="Tw: no standalone Tailwind CLI is published for this OS/architecture. Install it yourself and set &lt;TailwindCliPath&gt;, or set &lt;TwUseCssPipeline&gt;false&lt;/TwUseCssPipeline&gt; to use the built-in parser." />

    <Message Importance="high" Text="Tw: downloading the Tailwind CLI $(TailwindCliVersion) (one time, ~110 MB) → $(TailwindCliPath)" />

    <DownloadFile SourceUrl="$(_TwCliUrl)"
                  DestinationFolder="$(_TwCliCacheDir)"
                  DestinationFileName="$(_TwCliAsset)"
                  Retries="3"
                  SkipUnchangedFiles="true" />

    <!-- The GitHub release asset carries no execute bit on Unix. -->
    <Exec Condition="!$([MSBuild]::IsOSPlatform('Windows'))"
          Command="chmod +x &quot;$(TailwindCliPath)&quot;"
          StandardOutputImportance="low" />
  </Target>

  <!--
    Inputs/Outputs make this incremental: Tailwind only re-runs when the entry stylesheet or a file
    that could carry a class string has changed. Tailwind's own scanner decides which candidates
    actually exist; MSBuild only decides *whether* to ask it again.
  -->
  <!--
    The generator identifies the compiled stylesheet by this path, not by filename or item metadata.
    Both alternatives are traps here:
      * By filename — the MAUI SDK globs *.css as MauiCss and puts the project's *entry* stylesheet
        into AdditionalFiles on its own. That file holds only @import/@custom-variant and no rules,
        so loading it makes every utility look "unknown".
      * By item metadata — metadata reaches a generator through the generated .editorconfig, and an
        AdditionalFiles item added from a target does not reliably appear in it.
    A compiler-visible property is unambiguous and is the mechanism already used for TargetFramework.
  -->
  <ItemGroup Condition="'$(_TwCssEnabled)' == 'true'">
    <CompilerVisibleProperty Include="TwGeneratedCss" />
  </ItemGroup>

  <Target Name="TwBuildCss"
          DependsOnTargets="TwWriteDefaultEntry;TwRestoreCli"
          BeforeTargets="CoreCompile"
          Condition="'$(_TwCssEnabled)' == 'true'"
          Inputs="$(TwCssEntry);@(Compile);@(MauiXaml)"
          Outputs="$(TwGeneratedCss)">

    <MakeDir Directories="$(TwIntermediateDir)" />
    <Message Importance="normal" Text="Tw: compiling $(TwCssEntry) → $(TwGeneratedCss)" />

    <Exec Command="&quot;$(TailwindCliPath)&quot; --input &quot;$(TwCssEntry)&quot; --output &quot;$(TwGeneratedCss)&quot; --cwd &quot;$(MSBuildProjectDirectory)&quot;"
          StandardOutputImportance="low"
          StandardErrorImportance="normal" />
  </Target>

  <!--
    Registering the AdditionalFile must NOT depend on the file already existing: on a clean build
    the stylesheet does not exist when target conditions are evaluated, and a target skipped that
    way never runs its dependency either — TwBuildCss would deadlock behind its own output. So this
    target is unconditional (beyond the pipeline being on) and simply runs after the compile step.
    It is separate from TwBuildCss because MSBuild skips an up-to-date target's tasks entirely, and
    an incremental build must still hand the (unchanged) CSS to the generator.

    It must also run before GenerateMSBuildEditorConfigFile (note the File suffix — that is the real
    target name in Microsoft.Managed.Core.targets), which is what actually transports item metadata
    to the generator. Registering the item after that target has run leaves the generator seeing an
    AdditionalFile with no TwGeneratedCss metadata — it silently falls back to the class-name parser,
    and the only visible symptom is Tailwind v3 colours in the output.
  -->
  <Target Name="TwAddCssToCompiler"
          DependsOnTargets="TwBuildCss"
          BeforeTargets="GenerateMSBuildEditorConfigFile;CoreCompile"
          Condition="'$(_TwCssEnabled)' == 'true'">
    <ItemGroup>
      <AdditionalFiles Include="$(TwGeneratedCss)" TwGeneratedCss="true" Visible="false" />

      <!--
        Embed the same stylesheet the generator used. Class strings that cannot be precompiled —
        interpolated strings, and idiom: variants that depend on the running device — are resolved
        against it at runtime, so the app has ONE Tailwind vocabulary rather than two.

        Set TwEmbedStylesheet=false to drop it (saves ~40 KB) if every class string in the app is a
        literal; dynamic strings then fall back to the built-in parser, whose tables may disagree.
      -->
      <EmbeddedResource Include="$(TwGeneratedCss)"
                        Condition="'$(TwEmbedStylesheet)' != 'false'"
                        LogicalName="Tw.tailwind.css"
                        Visible="false" />
    </ItemGroup>
  </Target>

</Project>
